# Open Jira — Environment Configuration
# Copy this file to .env and edit before running docker compose.
#
#   cp .env.example .env
#   docker compose -f deploy/docker/docker-compose.yml up -d --build

# --- Required ---
APP_SECRET=change-me                     # JWT signing secret (required)
DB_DSN=postgres://user:pass@localhost:5432/heureum?sslmode=disable  # required

# --- Optional (with defaults) ---
APP_PORT=8080
APP_ENV=development
APP_BASE_URL=http://localhost:8080
DB_DRIVER=postgres                       # postgres | mysql | sqlite
REDIS_URL=redis://localhost:6379/0
APP_UPLOADS_DIR=./data/uploads           # local disk path for issue attachments
APP_SIGNUP=open                          # open | closed — disable public registration
API_PORT=8080                            # compose-only: host port published for the api service

# --- SMTP (notification email; read by the worker) ---
# Set these to enable notification emails. Leave SMTP_HOST empty to disable email
# (the worker then only delivers in-app notifications). SMTP_USER/PASS are optional
# (omit for an unauthenticated relay); SMTP_PORT defaults to 587.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=heureum@example.com
# SMTP_PASS=change-me
# SMTP_FROM=heureum@example.com

# --- Planned (NOT yet read by the app) ---
# OAuth (Forgejo/GitLab/GitHub) is configured per-project in the DB, not via env.
# Object storage (S3) for attachments/avatars is planned; today they use local disk.
