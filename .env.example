# Open Jira — Environment Configuration
# Copy this file to .env and edit before running docker compose.
#
#   cp .env.example .env
#   docker compose -f deploy/docker/docker-compose.yml up -d --build

# ── REQUIRED ──────────────────────────────────────────────────────────────────
# JWT signing secret — use at least 32 random characters
APP_SECRET=changeme-please-set-a-real-secret-min-32-chars

# ── OPTIONAL (defaults shown) ─────────────────────────────────────────────────
APP_ENV=development
APP_BASE_URL=http://localhost
APP_PORT=80          # port nginx listens on (host)

# SMTP (email notifications — leave blank to disable)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@openjira.local
