# Open Jira Configuration
# Copy this file to .env and fill in your values

APP_SECRET=changeme-please-set-a-real-secret-min-32-chars
APP_BASE_URL=http://localhost:9090
APP_PORT=9090

# SMTP (optional - for email notifications)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@openjira.local
